{
  "name": "governance-sdk-platform",
  "version": "0.1.3",
  "description": "Platform storage layer for governance-sdk — auto-migrating schema, typed queries for org settings and policy tiers",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "tsx --test src/*.test.ts",
    "lint": "tsc --noEmit"
  },
  "author": "Lua <hello@heylua.ai> (https://heylua.ai)",
  "license": "MIT",
  "keywords": [
    "governance-sdk",
    "ai-governance",
    "storage",
    "postgresql",
    "postgres",
    "platform",
    "audit-trail",
    "policy-tiers"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lua-ai-global/governance",
    "directory": "packages/governance-platform"
  },
  "bugs": {
    "url": "https://github.com/lua-ai-global/governance/issues"
  },
  "homepage": "https://heygovernance.ai",
  "peerDependencies": {
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "pg": { "optional": true }
  },
  "devDependencies": {
    "tsx": "^4.22.0",
    "typescript": "^5.7.0"
  }
}
